          "type": "text",
          "text": "```typescript\nexport function toposort<T>(nodes: T[], edges: [T, T][]): T[] {\n  if (!Array.isArray(nodes)) {\n    throw new Error(\"nodes must be an array\");\n  }\n  if (!Array.isArray(edges)) {\n    throw new Error(\"edges must be an array\");\n  }\n\n  // Handle empty graph\n  if (nodes.length === 0) {\n    return [];\n  }\n\n  // Build adjacency list\n  const graph = new Map<T, T[]>();\n  const nodeSet = new Set(nodes);\n\n  for (const node of nodes) {\n    graph.set(node, []);\n  }\n\n  for (const [u, v] of edges) {\n    if (!nodeSet.has(u)) {\n      throw new Error(\"Edge source node not in nodes list\");\n    }\n    if (!nodeSet.has(v)) {\n      throw new Error(\"Edge target node not in nodes list\");\n    }\n    graph.get(u)!.push(v);\n  }\n\n  // DFS-based topological sort with cycle detection\n  const result: T[] = [];\n  const color = new Map<T, \"white\" | \"gray\" | \"black\">();\n\n  for (const node of nodes) {\n    color.set(node, \"white\");\n  }\n\n  function dfs(node: T): void {\n    const currentColor = color.get(node);\n\n    if (currentColor === \"gray\") {\n      throw new Error(\"Cycle detected in directed graph\");\n    }\n\n    if (currentColor === \"black\") {\n      return;\n    }\n\n    color.set(node, \"gray\");\n    const neighbors = graph.get(node);\n\n    if (neighbors) {\n      for (const neighbor of neighbors) {\n        dfs(neighbor);\n      }\n    }\n\n    color.set(node, \"black\");\n    result.push(node);\n  }\n\n  for (const node of nodes) {\n    if (color.get(node) === \"white\") {\n      dfs(node);\n    }\n  }\n\n  return result.reverse();\n}\n```\n\n**Potential bugs fixed:**\n\n1. **Missing input validation** — Added `Array.isArray()` checks to ensure nodes and edges are valid arrays before processing, preventing `TypeError` on null/undefined input.\n\n2. **Unvalidated edge references** — Added `nodeSet.has()` checks to verify both source and target nodes of each edge exist in the nodes array, preventing silent ignoring of invalid edges.\n\n3. **Inefficient topological ordering** — Changed from `unshift()` (O(n²)) to `push()` + `reverse()` (O(n)) for correct final ordering without quadratic overhead."
        }
